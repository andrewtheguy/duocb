// The start-a-connection screen: per-mode hosting credentials plus the
// session panel once paired. Every mode starts straight from its launch
// screen, so the not-running state is a brief teardown transient.

import { UiState, Actions } from "globals.slint";
import { PairMode } from "types.slint";
import { Theme } from "theme.slint";
import { Card, Body, Weak, Small, Mono, BackHeader, TokenPairingSummary, LabeledValue } from "widgets.slint";
import { SessionPanel } from "session.slint";
import { Button, LineEdit, ScrollView } from "std-widgets.slint";

export component ServerScreen inherits ScrollView {
    out property <bool> field-focused: session.field-focused;
    viewport-width: root.width;
    viewport-height: max(root.height, content.preferred-height);
    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
    mouse-drag-pan-enabled: true;

    content := VerticalLayout {
        alignment: start;
        spacing: Theme.pad-m;

        BackHeader { title: "Start a connection"; }
        Body { text: "Status: " + UiState.status-text; }

        if UiState.server-running && UiState.mode == PairMode.nostr-token: VerticalLayout {
            spacing: Theme.pad-s;
            TokenPairingSummary { }
            Small {
                text: "Your other devices see this one as hosting — pick it in their list to join.";
            }
        }

        if UiState.server-running && UiState.mode == PairMode.nostr-pin
            && UiState.pin-display != "": VerticalLayout {
            spacing: Theme.pad-xs;
            alignment: start;
            Body {
                text: "Type this PIN on the other device:";
                horizontal-alignment: center;
            }
            Text {
                text: UiState.pin-display;
                font-family: UiState.mono-font;
                font-size: Theme.font-pin;
                font-weight: 700;
                horizontal-alignment: center;
            }
            HorizontalLayout {
                alignment: center;
                Button {
                    text: "Copy PIN (" + UiState.cmd-label + "+T)";
                    clicked => { Actions.copy-pin(); }
                }
            }
            Body {
                text: UiState.pin-countdown;
                horizontal-alignment: center;
            }
        }
        if UiState.server-running && UiState.mode == PairMode.nostr-pin
            && UiState.pin-display == "" && UiState.pin-paired
            && UiState.node-id-short != "": VerticalLayout {
            spacing: Theme.pad-xs;
            // Paired: the PIN is spent. Show this device's node id — the
            // same value the other device displays as "Paired with:" — so
            // the user can eyeball that the two match.
            LabeledValue { label: "This device's id:"; value: UiState.node-id-short; }
            Small { text: "Confirm this matches “Paired with” on the other device."; }
        }

        // The pairing code bundles the node id and the session secret; it is
        // shown in the clear like a PIN (its holder can pair anyway, and the
        // session is claimed by the first peer). It stays valid (and copyable)
        // for the whole session so the paired peer can be re-sent it and
        // reconnect after a drop.
        if UiState.server-running && UiState.mode == PairMode.manual
            && UiState.pairing-code != "": VerticalLayout {
            spacing: Theme.pad-xs;
            HorizontalLayout {
                spacing: Theme.pad-s;
                alignment: start;
                Body { text: "Pairing code:"; vertical-alignment: center; }
                Button {
                    text: "Copy (" + UiState.cmd-label + "+T)";
                    clicked => { Actions.copy-pairing-code(); }
                }
            }
            Mono { text: UiState.pairing-code; wrap: char-wrap; }
            Body { text: "Send it to the other device over any channel you trust and paste it there."; }
            Small { text: "Manual mode uses no signaling service (no nostr) — only iroh. It resolves the id in the code over the internet (iroh's DNS) or the local network (mDNS), then connects directly or through an iroh relay. Devices on the same network can link directly even while online, and can pair with no internet at all."; }
        }

        if UiState.server-running: HorizontalLayout {
            alignment: start;
            Button {
                text: "⏹ Stop";
                clicked => { Actions.go-back(); }
            }
        }

        session := SessionPanel { }
    }
}
