// The quick-options screen: pick an ad-hoc mode, then start or join. Nothing
// here is persisted; the credentials last one session.

import { UiState, Actions } from "globals.slint";
import { PairMode } from "types.slint";
import { Theme } from "theme.slint";
import { Card, CardTitle, Weak, Small, Body, BigButton, WideButton, BackHeader, SelectableRow } from "widgets.slint";

component ModeRow inherits SelectableRow {
    in property <string> text;
    /// Renders the row de-emphasized (the testing-only manual mode).
    in property <bool> demoted;
    opacity: root.demoted && !root.selected ? Theme.weak-opacity : 1.0;
    Text {
        text: root.selected ? "●" : "○";
        font-size: Theme.font-body;
        vertical-alignment: center;
    }
    Body { text: root.text; vertical-alignment: center; }
}

export component QuickScreen inherits Rectangle {
    out property <bool> field-focused: false;

    VerticalLayout {
        alignment: start;
        spacing: Theme.pad-m;

        BackHeader { title: "Quick options"; }
        Weak {
            text: "Pair on the spot — nothing is saved, and the credentials last one session.";
        }

        Card {
            CardTitle { text: "Mode"; }
            ModeRow {
                text: "P  PIN quick pair — type a short rotating code (internet)";
                selected: UiState.mode == PairMode.nostr-pin;
                clicked => { Actions.set-mode(PairMode.nostr-pin); }
            }
            ModeRow {
                demoted: true;
                text: "M  Manual (testing) — node id + token, no nostr";
                selected: UiState.mode == PairMode.manual;
                clicked => { Actions.set-mode(PairMode.manual); }
            }
            Small {
                text: "Manual is for testing connectivity without nostr — offline on the same LAN (mDNS) or across the internet. Everyday pairing is the PIN.";
            }
        }

        BigButton {
            text: "🚀 Start a connection";
            hint: "S";
            clicked => { Actions.begin-server(); }
        }
        WideButton {
            text: "🔗 Join a connection";
            hint: "C";
            clicked => { Actions.open-client(); }
        }
    }
}
