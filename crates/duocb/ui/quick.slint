// The quick-options screen: pick an ad-hoc mode, then start or join. Nothing
// here is persisted; the credentials last one session.

import { UiState, Actions } from "globals.slint";
import { PairMode, PinChannel } from "types.slint";
import { Theme } from "theme.slint";
import { Card, CardTitle, Weak, Small, Body, BigButton, WideButton, BackHeader, SelectableRow } from "widgets.slint";
import { ScrollView } from "std-widgets.slint";

component ModeRow inherits SelectableRow {
    in property <string> text;
    /// Renders the row de-emphasized (the testing-only manual mode).
    in property <bool> demoted;
    opacity: root.demoted && !root.selected ? Theme.weak-opacity : 1.0;
    Text {
        text: root.selected ? "●" : "○";
        font-size: Theme.font-body;
        vertical-alignment: center;
    }
    Body {
        text: root.text;
        horizontal-stretch: 1;
        vertical-alignment: center;
    }
}

export component QuickScreen inherits ScrollView {
    out property <bool> field-focused: false;
    viewport-width: root.width;
    viewport-height: max(root.height, content.preferred-height);
    horizontal-scrollbar-policy: ScrollBarPolicy.always-off;
    mouse-drag-pan-enabled: true;

    content := VerticalLayout {
        alignment: start;
        spacing: Theme.pad-m;

        BackHeader { title: "Quick options"; }
        Weak {
            text: "Pair on the spot — nothing is saved, and the credentials last one session.";
        }

        Card {
            CardTitle { text: "How to pair"; }
            ModeRow {
                text: "P  PIN quick pair — internet + local network (default)";
                selected: UiState.mode == PairMode.nostr-pin && UiState.pin-channel == PinChannel.both;
                clicked => {
                    Actions.set-mode(PairMode.nostr-pin);
                    Actions.set-pin-channel(PinChannel.both);
                }
            }
            Small {
                text: "Shows a short rotating code you type on the other device. It finds the other device over the internet (a nostr relay) and your local network at the same time, so it pairs whether or not you share a network — the everyday choice.";
            }
            ModeRow {
                text: "L  Local network only — private";
                selected: UiState.mode == PairMode.nostr-pin && UiState.pin-channel == PinChannel.lan-only;
                clicked => {
                    Actions.set-mode(PairMode.nostr-pin);
                    Actions.set-pin-channel(PinChannel.lan-only);
                }
            }
            Small {
                text: "Private means no third-party server participates: discovery is mDNS-only and traffic is always direct between the devices, never relayed. LAN-only is not a packet-level subnet boundary; reflected mDNS, a VPN/overlay, or globally routed addresses can extend the direct path beyond a conventional LAN. Does not pair with the iOS app — use P for that.";
            }
        }

        // Uncommon options, mostly for testing — collapsed behind a disclosure
        // until expanded (or until one of them is the active selection).
        Card {
            SelectableRow {
                clicked => { Actions.toggle-quick-advanced(); }
                Text {
                    text: UiState.quick-advanced-open ? "▾" : "▸";
                    font-size: Theme.font-body;
                    vertical-alignment: center;
                }
                CardTitle { text: "Uncommon options"; vertical-alignment: center; }
            }
            if UiState.quick-advanced-open: Small {
                text: "Mostly for testing — the two above cover everyday pairing.";
            }
            if UiState.quick-advanced-open: ModeRow {
                demoted: true;
                text: "I  Internet only";
                selected: UiState.mode == PairMode.nostr-pin && UiState.pin-channel == PinChannel.nostr-only;
                clicked => {
                    Actions.set-mode(PairMode.nostr-pin);
                    Actions.set-pin-channel(PinChannel.nostr-only);
                }
            }
            if UiState.quick-advanced-open: Small {
                text: "Finds the peer through a nostr relay only — its PIN is never advertised on the local network — so pairing needs the internet. The connection itself still uses iroh's default paths, so it can take a direct local route when both devices share a network.";
            }
            if UiState.quick-advanced-open: ModeRow {
                demoted: true;
                text: "M  Manual";
                selected: UiState.mode == PairMode.manual;
                clicked => { Actions.set-mode(PairMode.manual); }
            }
            if UiState.quick-advanced-open: Small {
                text: "No discovery at all: copy one pairing code between the devices out of band — on the same network or across the internet. Verifies connectivity with zero signaling.";
            }
        }

        BigButton {
            text: "🚀 Start a connection";
            hint: "S";
            clicked => { Actions.begin-server(); }
        }
        WideButton {
            text: "🔗 Join a connection";
            hint: "C";
            clicked => { Actions.open-client(); }
        }
    }
}
